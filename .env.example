DATABASE_URI=postgresql://your_db_user:your_db_password@localhost:5434/monte_magic
PAYLOAD_SECRET=your_secret_key_min_32_characters_long
NEXT_PUBLIC_SERVER_URL=http://localhost:3006

# Optional: auto-create first admin during seed
# ADMIN_EMAIL=admin@montemagic.local
# ADMIN_PASSWORD=replace_with_strong_password

# Optional: Email notifications (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# SMTP_PORT=587
# NOTIFICATION_EMAIL=owner@email.com

# Optional: Telegram Bot notifications
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=your_chat_id
